<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondomain"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="0dp"
    tools:ignore="Overdraw">

    <!-- Logo de la app -->
    <ImageView
        android:id="@+id/roundedImageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/logo_description"
        android:src="@drawable/logo" />

    <!-- Botón de activación manual, justo debajo del logo con poco margen superior -->
    <Button
        android:id="@+id/btnManualActivation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/hold_to_activate_alarm" />

    <!-- Si hay otros elementos, se agregarían aquí -->
</LinearLayout>
