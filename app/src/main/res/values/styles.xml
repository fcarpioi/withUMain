<resources>
    <!-- Tema de la pantalla de inicio -->
    <style name="Theme.SplashScreen" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.MyApp.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Personaliza el fondo y el estilo aquí si es necesario -->
        <item name="android:windowBackground">@color/black</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Tema moderno para la aplicación -->
    <style name="Theme.Modern" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/modernOrange</item>
        <item name="colorPrimaryVariant">@color/modernOrangeDark</item>
        <item name="colorOnPrimary">@color/modernBackgroundSecondary</item>
        <item name="colorSecondary">@color/modernAccent</item>
        <item name="colorSecondaryVariant">@color/modernOrangeLight</item>
        <item name="colorOnSecondary">@color/modernBackgroundSecondary</item>
        <item name="android:windowBackground">@drawable/modern_gradient_background</item>
        <item name="android:statusBarColor">@color/backgroundColor</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
