rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function locationRequestBelongsToCaller() {
      return isSignedIn() && (
        (request.resource.data.userId is string &&
          request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.user_id is string &&
          request.resource.data.user_id == request.auth.uid)
      );
    }

    function locationResourceBelongsToCaller() {
      return isSignedIn() && (
        (resource.data.userId is string &&
          resource.data.userId == request.auth.uid) ||
        (resource.data.user_id is string &&
          resource.data.user_id == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /devices/{deviceId} {
        allow read, write: if isOwner(userId);

        // Cubre locations, recordings, photos, usage, screenshots y futuras subcolecciones.
        match /{document=**} {
          allow read, write: if isOwner(userId);
        }
      }

      match /notifications/{document=**} {
        allow read, write: if isOwner(userId);
      }

      match /payments/{document=**} {
        allow read, write: if isOwner(userId);
      }

      match /tokens/{document=**} {
        allow read, write: if isOwner(userId);
      }

      match /sms/{document=**} {
        allow read, write: if isOwner(userId);
      }

      // Fallback para otras subcolecciones del usuario que ya usa la app.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Colección legacy de ubicaciones.
    match /locations/{locationId} {
      allow create: if locationRequestBelongsToCaller();
      allow read, update, delete: if locationResourceBelongsToCaller();
    }

    // Histórico legacy usado por flujos externos.
    match /historydevices/{document=**} {
      allow read, create: if true;
      allow write, delete: if false;
    }

    match /subscriptions/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
